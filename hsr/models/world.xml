<mujoco model="world">
    <option impratio="2.5" timestep="0.002"/>
    <default>
        <geom condim="4" solimp="0.99 0.99 0.01" solref="0.01 1"/>
        <default class="wall">
            <geom rgba="2 2 2 1"/>
        </default>
        <default class="floor">
            <geom rgba=".4 .3 .2 1"/>
        </default>
        <default class="furniture">
            <geom rgba="1 1 .8 1"/>
        </default>

        <default class="box">
            <geom rgba=".7 .7 .7 1"/>
        </default>
        <default class="clear">
            <geom rgba=".7 .7 .7 .2"/>
        </default>
        <default class="cubby">
            <geom rgba=".9 .9 .7 1"/>
        </default>
        <default class="block2x4">
            <geom type="box" size=".0635 .0317 .0234"/>
        </default>

        <!--<default class="block2x2">-->
        <!--<geom type="box" size=".0317 .0317 .0234"/>-->
        <!--<joint name='boxx' type='slide' axis='1 0 0' limited='false' damping='.01'/>-->
        <!--<joint name='boxy' type='slide' axis='0 1 0' limited='false' damping='.01'/>-->
        <!--<joint name='boxz' type='slide' axis='0 0 1' limited='false' damping='.01'/>-->
        <!--</default>-->

    </default>
    <option cone="elliptic"/>
    <visual>
        <!-- Strong ambient + headlight so surfaces are never near-black like the real,
             bounce-lit rooms the policy was trained on (was: dim single light -> black void). -->
        <headlight ambient="0.24 0.24 0.24" diffuse="0.15 0.15 0.15" specular="0.12 0.12 0.12"/>
        <!-- Crisp soft shadows + multisampling for realism. -->
        <quality shadowsize="4096" offsamples="8"/>
        <!-- Clip planes are FRACTIONS of stat.extent (pinned below to 2 m), so near
             plane = 0.015*2 = 0.03 m and far = 12*2 = 24 m. Without pinning, the big
             room inflated stat.extent to ~10 m and pushed the near plane to 0.32 m,
             which clipped the robot's own arm and any close object in the on-robot
             cameras (geoms went see-through / vanished off-center). -->
        <map znear="0.015" zfar="12" haze="0.1"/>
        <rgba haze="0.86 0.88 0.90 1"/>
        <global offwidth="1000" offheight="1000" azimuth="150" elevation="-20"/>
    </visual>
    <compiler coordinate="local" angle="radian" meshdir="../hsr_meshes/meshes/" texturedir="../hsr_textures/textures/" inertiafromgeom="auto"/>
    <size njmax="500" nconmax="100"/>
    <!-- Pin model extent to the workspace scale so camera near/far clip planes (which
         scale with stat.extent) stay correct regardless of the enclosing room size. -->
    <statistic extent="2" center="0 0 0.6"/>

    <asset>
        <mesh name="base_light" file="base_v2/base_light.stl"/>
        <mesh name="body_light" file="base_v2/body_light.stl"/>
        <mesh name="torso_base" file="base_v2/torso_base.stl"/>
        <mesh name="base" file="base_v2/base.stl"/>
        <mesh name="laser" file="sensors/laser.stl"/>
        <mesh name="torso_light" file="torso_v0/torso_light.stl"/>
        <mesh name="torso" file="torso_v0/torso.stl"/>
        <mesh name="head_pan" file="head_v1/head_pan.stl"/>
        <mesh name="head_upper" file="head_v1/head_upper.stl"/>
        <mesh name="head_tilt" file="head_v1/head_tilt.stl"/>
        <mesh name="tablet_base" file="head_v1/tablet_base.stl"/>
        <mesh name="head" file="head_v1/head.stl"/>
        <mesh name="tablet" file="head_v1/tablet.stl"/>
        <mesh name="head_camera" file="sensors/head_camera.stl"/>
        <mesh name="rgbd_light" file="sensors/rgbd_light.stl"/>
        <mesh name="rgbd" file="sensors/rgbd.stl"/>
        <mesh name="shoulder" file="arm_v0/shoulder.stl"/>
        <mesh name="arm_flex_light" file="arm_v0/arm_flex_light.stl"/>
        <mesh name="arm_flex" file="arm_v0/arm_flex.stl"/>
        <mesh name="arm_roll_light" file="arm_v0/arm_roll_light.stl"/>
        <mesh name="arm_roll" file="arm_v0/arm_roll.stl"/>
        <mesh name="wrist_flex" file="wrist_v0/wrist_flex.stl"/>
        <mesh name="wrist_roll" file="wrist_v0/wrist_roll.stl"/>
        <mesh name="palm" file="hand_v0/palm.stl"/>
        <mesh name="l_proximal" file="hand_v0/l_proximal.stl"/>
        <mesh name="l_distal" file="hand_v0/l_distal.stl"/>
        <mesh name="r_proximal" file="hand_v0/r_proximal.stl"/>
        <mesh name="r_distal" file="hand_v0/r_distal.stl"/>

        <!-- ===== Realism: scene textures & materials ===== -->
        <!-- Neutral light-gray gradient: an open top reads as a bright ceiling, not blue
             sky (the wide hand camera can glimpse it, so keep it color-neutral). -->
        <texture name="skytex" type="skybox" builtin="gradient"
                 rgb1="0.88 0.88 0.86" rgb2="0.62 0.62 0.63" width="512" height="3072"/>
        <!-- Tiled marble floor (real lab/home floor) from the existing texture pack. -->
        <texture name="floortex" type="2d" file="floor.png"/>
        <material name="floormat" texture="floortex" texrepeat="6 6" texuniform="true"
                  rgba="0.72 0.70 0.66 1" specular="0.2" shininess="0.3" reflectance="0.04"/>
        <!-- White melamine worktable, matching the real AIRoA desk (white, slight sheen). -->
        <material name="tablemat" rgba="0.84 0.84 0.83 1" specular="0.4" shininess="0.5" reflectance="0.05"/>
        <!-- Matte painted wall (neutral mid-gray, matching the real room). -->
        <material name="wallmat" rgba="0.68 0.68 0.66 1" specular="0.1" shininess="0.1" reflectance="0.0"/>
        <!-- Glossy ceramic mug. -->
        <material name="cupmat" rgba="0.20 0.45 0.82 1" specular="0.6" shininess="0.6" reflectance="0.1"/>
    </asset>
    <worldbody>
        <!-- ===== Realism: lighting. Directional (sun-like) so the room is evenly lit
             with no spotlight hot-spot; one key casts soft shadows, two dim fills
             soften the shadow side. (Directional lights + a closed ceiling would put
             the whole floor in the ceiling's shadow, so the ceiling is left open.) ===== -->
        <light name="key" directional="true" dir="-0.2 -0.35 -1"
               diffuse="0.4 0.4 0.38" specular="0.22 0.22 0.22" castshadow="true"/>
        <light name="fill_l" directional="true" dir="0.35 -0.5 -0.7"
               diffuse="0.13 0.13 0.13" specular="0 0 0" castshadow="false"/>
        <light name="fill_r" directional="true" dir="0.35 0.5 -0.7"
               diffuse="0.13 0.13 0.13" specular="0 0 0" castshadow="false"/>

        <!-- ===== Realism: textured floor (enlarged to fill the room) ===== -->
        <geom name="floor" type="plane" size="4 4 0.1" pos="0 0 0" material="floormat"/>

        <!-- ===== Realism: room walls + ceiling. Visual only (contype/conaffinity 0)
             so they give the head camera a real background without ever adding contacts
             the policy never saw in the real-world training data. ===== -->
        <geom name="wall_px" type="box" pos="2.5 0 1.4"  size="0.05 2.5 1.4" material="wallmat" contype="0" conaffinity="0"/>
        <geom name="wall_nx" type="box" pos="-2.5 0 1.4" size="0.05 2.5 1.4" material="wallmat" contype="0" conaffinity="0"/>
        <geom name="wall_py" type="box" pos="0 2.5 1.4"  size="2.5 0.05 1.4" material="wallmat" contype="0" conaffinity="0"/>
        <geom name="wall_ny" type="box" pos="0 -2.5 1.4" size="2.5 0.05 1.4" material="wallmat" contype="0" conaffinity="0"/>

        <body name="goal" pos="0 0 0" mocap="true">
            <!-- Invisible to cameras: real training images have no debug marker. -->
            <site name="goal" size=".01 .01 .01" pos="0 0 0" rgba="0 1 0 0"/>
        </body>

        <body name="pan" pos="0 0 .4">
            <geom type="box" size=".17 .2667 .005" material="tablemat"/>
            <!-- Visual-only legs (no collision) so the worktable reads as real furniture. -->
            <geom type="box" pos=" .15  .24 -.2" size=".015 .015 .2" material="tablemat" contype="0" conaffinity="0"/>
            <geom type="box" pos=" .15 -.24 -.2" size=".015 .015 .2" material="tablemat" contype="0" conaffinity="0"/>
            <geom type="box" pos="-.15  .24 -.2" size=".015 .015 .2" material="tablemat" contype="0" conaffinity="0"/>
            <geom type="box" pos="-.15 -.24 -.2" size=".015 .015 .2" material="tablemat" contype="0" conaffinity="0"/>
            <!--<geom type="box" size=".001  .2667 .01" pos=".17 0  .01"  class="clear"/>-->
            <!--<geom type="box" size=".001  .2667 .01" pos="-.17 0 .01" class="clear"/>-->
            <!--<geom type="box" size=".17 .001  .01" pos="0 .2667  .01"  class="clear"/>-->
            <!--<geom type="box" size=".17 .001  .01" pos="0 -.2667 .01" class="clear"/>-->
        </body>

<!--        <body name="block" pos="0 0 .418">-->
<!--          <geom name="block" type="box" mass="1" size=".05 .025 .017" rgba=".8 .1 .1 1" condim="6" solimp="0.99 0.99 0.01" solref="0.01 1"/>-->
<!--          <freejoint name='blockjoint'/>-->
<!--        </body>-->
        <body name="cup" pos="-.1 0.2 .423" euler="0 0 90">
        <freejoint name="cupjoint"/>
        <!-- mug body: cylinder upright along z, sitting on its base -->
        <geom name="cup_body" type="cylinder" size=".04 .05" pos="0 0 .05" mass=".22"
                condim="6" solimp="0.99 0.99 0.01" solref="0.01 1" material="cupmat"/>
        <!-- handle: 4 capsules forming a C on the +x side; fromto = the two endpoints, the single size value is the radius -->
        <geom name="cup_h0" type="capsule" size=".006" fromto="0.040 0 0.078  0.070 0 0.072" mass=".01" condim="6" solimp="0.99 0.99 0.01" solref="0.01 1" material="cupmat"/>
        <geom name="cup_h1" type="capsule" size=".006" fromto="0.070 0 0.072  0.078 0 0.054" mass=".01" condim="6" solimp="0.99 0.99 0.01" solref="0.01 1" material="cupmat"/>
        <geom name="cup_h2" type="capsule" size=".006" fromto="0.078 0 0.054  0.070 0 0.036" mass=".01" condim="6" solimp="0.99 0.99 0.01" solref="0.01 1" material="cupmat"/>
        <geom name="cup_h3" type="capsule" size=".006" fromto="0.070 0 0.036  0.040 0 0.030" mass=".01" condim="6" solimp="0.99 0.99 0.01" solref="0.01 1" material="cupmat"/>
        </body>

        <body name="cup2" pos="-.1 -.12 .423" euler="0 0 90">
        <freejoint name="cupjoint2"/>
        <!-- mug body: cylinder upright along z, sitting on its base -->
        <geom name="cup_body2" type="cylinder" size=".04 .05" pos="0 0 .05" mass=".22"
                condim="6" solimp="0.99 0.99 0.01" solref="0.01 1" rgba="0.8 0.1 0.1 1"/>
        <!-- handle: 4 capsules forming a C on the +x side; fromto = the two endpoints, the single size value is the radius -->
        <geom name="cup_h02" type="capsule" size=".006" fromto="0.040 0 0.078  0.070 0 0.072" mass=".01" condim="6" solimp="0.99 0.99 0.01" solref="0.01 1" rgba="0.8 0.1 0.1 1"/>
        <geom name="cup_h12" type="capsule" size=".006" fromto="0.070 0 0.072  0.078 0 0.054" mass=".01" condim="6" solimp="0.99 0.99 0.01" solref="0.01 1" rgba="0.8 0.1 0.1 1"/>
        <geom name="cup_h22" type="capsule" size=".006" fromto="0.078 0 0.054  0.070 0 0.036" mass=".01" condim="6" solimp="0.99 0.99 0.01" solref="0.01 1" rgba="0.8 0.1 0.1 1"/>
        <geom name="cup_h32" type="capsule" size=".006" fromto="0.070 0 0.036  0.040 0 0.030" mass=".01" condim="6" solimp="0.99 0.99 0.01" solref="0.01 1" rgba="0.8 0.1 0.1 1"/>
        </body>

        <!--<body name="block2" pos="0 0 .44">-->
          <!--<geom type="box" size=".0317 .0317 .0234" rgba=".1 .8 .1 1" condim="4" solimp="0.99 0.99 0.01" solref="0.01 1"/>-->
          <!--<freejoint name='box2joint'/>-->
        <!--</body>-->

        <include file="hsr.mjcf"/>
    </worldbody>
    <actuator>
        <!-- Action indices 0-7: Absolute position control for arm/head joints -->
        <!-- Ordering matches training schema: arm_lift, arm_flex, arm_roll, wrist_flex, wrist_roll, hand_motor, head_pan, head_tilt -->
        <position gear="1" kp="5000" dampratio="1" name="arm_lift_motor" joint="arm_lift_joint"
                  forcelimited="true" forcerange="-100 100"
                  ctrllimited="true" ctrlrange="0 0.34"/>
        <position gear="1" kp="1000" dampratio="1" name="arm_flex_motor" joint="arm_flex_joint"
                  forcelimited="true" forcerange="-15 35"
                  ctrllimited="true" ctrlrange="-2.62 0"/>
        <position gear="1" kp="1000" dampratio="1" name="arm_roll_motor" joint="arm_roll_joint"
                  forcelimited="true" forcerange="-20 20"
                  ctrllimited="true" ctrlrange="-2.09 3.84"/>
        <position gear="1" kp="1000" dampratio="1" name="wrist_flex_motor" joint="wrist_flex_joint"
                  forcelimited="true" forcerange="-20 20"
                  ctrllimited="true" ctrlrange="-1.919 1.221"/>
        <position gear="1" kp="1000" dampratio="1" name="wrist_roll_motor" joint="wrist_roll_joint"
                  forcelimited="true" forcerange="-20 20"
                  ctrllimited="true" ctrlrange="-1.92 3.67"/>
        <position gear="1" kp="100" dampratio="1" name="hand_motor" joint="hand_motor_joint"
                  forcelimited="true" forcerange="-20 20"
                  ctrllimited="true" ctrlrange="-0.798 1.239"/>
        <position gear="1" kp="500" dampratio="1" name="head_pan_motor" joint="head_pan_joint"
                  forcelimited="true" forcerange="-20 20"
                  ctrllimited="true" ctrlrange="-3.84 1.75"/>
        <position gear="1" kp="500" dampratio="1" name="head_tilt_motor" joint="head_tilt_joint"
                  forcelimited="true" forcerange="-20 20"
                  ctrllimited="true" ctrlrange="-1.57 0.52"/>

        <!-- Action indices 8-10: Base actuators (delta control applied in env.py) -->
        <!-- A position actuator servos gear*qpos = ctrl, so with gear!=1 the joint only
             reached ctrl/gear (base_x/y: 1/3 of command; base_roll: 1/5, i.e. +-36deg max),
             which broke the absolute base targeting in env.py. gear is set to 1 so ctrl maps
             1:1 to joint position. To preserve the previously-tuned dynamics, the joint-space
             stiffness (gear^2*kp) and force ceiling (gear*forcerange) are held constant:
             kp scaled by gear^2 and forcerange by gear. -->
        <position gear="1" kp="2700" dampratio="1" name="base_x_motor" joint="slide_x"
                  forcelimited="true" forcerange="-300 300"
                  ctrllimited="true" ctrlrange="-10 10"/>
        <position gear="1" kp="2700" dampratio="1" name="base_y_motor" joint="slide_y"
                  forcelimited="true" forcerange="-300 300"
                  ctrllimited="true" ctrlrange="-10 10"/>
        <position gear="1" kp="2500" name="base_roll_motor" joint="base_roll_joint"
                  forcelimited="true" forcerange="-500 500"
                  ctrllimited="true" ctrlrange="-3.14159 3.14159"/>

        <!-- Secondary coupled actuators for finger proximal joints -->
        <position gear="1" kp="1000" dampratio="1" name="hand_l_proximal_motor" joint="hand_l_proximal_joint"
                  forcelimited="true" forcerange="-20 20"
                  ctrllimited="true" ctrlrange="0 0.58"/>
        <position gear="1" kp="1000" dampratio="1" name="hand_r_proximal_motor" joint="hand_r_proximal_joint"
                  forcelimited="true" forcerange="-20 20"
                  ctrllimited="true" ctrlrange="0 0.58"/>

    </actuator>
    <contact>
        <exclude body1="base_link" body2="arm_lift_link"/>
        <exclude body1="arm_lift_link" body2="arm_flex_link"/>
        <exclude body1="arm_flex_link" body2="arm_roll_link"/>
        <exclude body1="arm_roll_link" body2="wrist_flex_link"/>
        <exclude body1="wrist_flex_link" body2="wrist_roll_link"/>
        <exclude body1="wrist_roll_link" body2="hand_palm_link"/>
        <exclude body1="arm_flex_link" body2="hand_palm_link"/>
        <exclude body1="arm_lift_link" body2="head_pan_link"/>
        <exclude body1="base_link" body2="arm_flex_link"/>
        <exclude body1="hand_palm_link" body2="hand_l_proximal_link"/>
        <exclude body1="hand_l_proximal_link" body2="hand_l_spring_proximal_link"/>
        <exclude body1="hand_l_spring_proximal_link" body2="hand_l_mimic_distal_link"/>
        <exclude body1="hand_l_mimic_distal_link" body2="hand_l_distal_link"/>
        <exclude body1="hand_palm_link" body2="hand_r_proximal_link"/>
        <exclude body1="hand_r_proximal_link" body2="hand_r_spring_proximal_link"/>
        <exclude body1="hand_r_spring_proximal_link" body2="hand_r_mimic_distal_link"/>
        <exclude body1="hand_r_mimic_distal_link" body2="hand_r_distal_link"/>
    </contact>
</mujoco>
